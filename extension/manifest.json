{
  "manifest_version": 3,
  "name": "Folio",
  "version": "1.0.0",
  "description": "Save job postings to Folio from any job board",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://localhost:3000/*"],
  "icons": {
    "128": "logo.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "logo.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/jobs/*",
        "*://*.indeed.com/viewjob*",
        "*://*.greenhouse.io/*/jobs/*",
        "*://*.lever.co/*"
      ],
      "js": ["content.js"]
    }
  ]
}
